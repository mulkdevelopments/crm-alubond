NODE_ENV=development
PORT=4001
API_PREFIX=/api/v1
FRONTEND_ORIGIN=http://localhost:3000
FILE_STORAGE_PROVIDER=vercel_blob
BLOB_ACCESS=private
BLOB_READ_WRITE_TOKEN=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Resend — create key at https://resend.com/api-keys (sending access for crm.alubond.com)
# On Render free tier, use the HTTP API key (SMTP ports 587/465 are blocked).
RESEND_API_KEY=
# Legacy alias; RESEND_API_KEY takes precedence when both are set.
SMTP_PASS=
EMAIL_FROM=Alubond CRM <no-reply@crm.alubond.com>
APP_BASE_URL=http://localhost:3000
DATABASE_URL=postgresql://alubond:alubond@localhost:5433/alubond_crm?schema=public
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
ADMIN_SETUP_KEY=replace-with-bootstrap-key
ADMIN_EMAIL=admin@alubondcrm.local
ADMIN_PASSWORD=Admin@12345
ADMIN_FIRST_NAME=System
ADMIN_LAST_NAME=Admin
