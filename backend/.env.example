NODE_ENV=development
PORT=4001
API_PREFIX=/api/v1
FRONTEND_ORIGIN=http://localhost:3000
FILE_STORAGE_PROVIDER=vercel_blob
BLOB_ACCESS=private
BLOB_READ_WRITE_TOKEN=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Resend SMTP — create key at https://resend.com/api-keys (sending_access for crm.alubond.com)
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=resend
SMTP_PASS=
EMAIL_FROM=Alubond CRM <no-reply@crm.alubond.com>
APP_BASE_URL=http://localhost:3000
DATABASE_URL=postgresql://alubond:alubond@localhost:5433/alubond_crm?schema=public
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=7d
ADMIN_SETUP_KEY=replace-with-bootstrap-key
ADMIN_EMAIL=admin@alubondcrm.local
ADMIN_PASSWORD=Admin@12345
ADMIN_FIRST_NAME=System
ADMIN_LAST_NAME=Admin
