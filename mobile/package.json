{
  "name": "mobile",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "expo": "~56.0.11",
    "expo-constants": "~56.0.18",
    "expo-document-picker": "~56.0.4",
    "expo-font": "~56.0.6",
    "expo-image-picker": "~56.0.17",
    "expo-linking": "~56.0.14",
    "expo-location": "~56.0.17",
    "expo-router": "~56.2.10",
    "expo-secure-store": "~56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-symbols": "~56.0.6",
    "expo-web-browser": "~56.0.5",
    "lucide-react-native": "^1.23.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-maps": "1.27.2",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "^15.15.5",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.8.3"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "build:preview:android": "eas build --platform android --profile preview --non-interactive",
    "build:preview:ios": "eas build --platform ios --profile preview --non-interactive",
    "build:preview": "eas build --platform all --profile preview --non-interactive",
    "build:android": "eas build --platform android --profile production --non-interactive",
    "build:ios": "eas build --platform ios --profile production --non-interactive",
    "build:testing": "eas build --platform all --profile production --non-interactive",
    "submit:android": "eas submit --platform android --profile production --latest --non-interactive",
    "submit:ios": "eas submit --platform ios --profile production --latest --non-interactive",
    "release:testing": "npm run build:testing && npm run submit:android && npm run submit:ios"
  },
  "private": true
}
